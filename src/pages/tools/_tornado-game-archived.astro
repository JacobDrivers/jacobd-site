---
import Layout from '../../layouts/Layout.astro';
---

<Layout 
  title="Tornado Destroyer | Jacob Drury" 
  description="Control a devastating tornado. Destroy buildings, watch realistic physics, and cause chaos. Amazing particle effects and tornado physics."
>
  <div class="game-container">
    <div class="game-header">
      <a class="back-btn" href="/tools" aria-label="Back to tools">← Tools</a>
      <div class="game-info">
        <div>
          <h1>Tornado Destroyer</h1>
          <div class="stats" role="status" aria-live="polite">
            <span class="stat">Damage: <span id="damage">0</span></span>
            <span class="stat">Score: <span id="score">0</span></span>
          </div>
        </div>
        <div class="controls-info">
          <span class="desktop-controls">WASD/Arrows: Move • Space: Increase Intensity</span>
          <span class="mobile-controls">Arrows to move • Tap bottom to boost</span>
        </div>
      </div>
    </div>
    <canvas id="gameCanvas" role="img" aria-label="Game canvas for Tornado Destroyer"></canvas>
    <div class="game-tips">
      <p>🌪️ Control a massive tornado from a mesocyclone • Destroy buildings and cause destruction</p>
      <p>💨 Space = Increase intensity & size • Watch debris fly • Realistic vortex physics</p>
      <p>🏢 Higher intensity = faster movement, more damage, bigger vortex</p>
    </div>
  </div>
</Layout>

<style>
  * {
    box-sizing: border-box;
  }

  .game-container {
    max-width: 100%;
    margin: 0 auto;
    padding: 10px;
    display: flex;
    flex-direction: column;
    align-items: center;
    min-height: 100vh;
  }

  .game-header {
    width: 100%;
    max-width: 1200px;
    display: flex;
    flex-direction: column;
    gap: 12px;
    margin-bottom: 12px;
    padding-bottom: 12px;
    border-bottom: 1px solid rgba(100, 116, 139, 0.3);
  }

  .game-header .back-btn {
    align-self: flex-start;
  }

  .game-info {
    display: flex;
    justify-content: space-between;
    align-items: flex-start;
    width: 100%;
    gap: 12px;
    flex-wrap: wrap;
  }

  .game-info h1 {
    margin: 0;
    font-size: 32px;
    background: linear-gradient(135deg, #ff6b35, #f7931e);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    background-clip: text;
    filter: drop-shadow(0 0 10px rgba(255, 107, 53, 0.3));
  }

  .stats {
    display: flex;
    gap: 16px;
    margin-top: 6px;
    font-size: 14px;
  }

  .stat {
    color: #94a3b8;
  }

  .stat span {
    color: #ff6b35;
    font-weight: bold;
  }

  .controls-info {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: 4px;
    font-size: 12px;
    color: #64748b;
  }

  .mobile-controls {
    display: none;
  }

  @media (max-width: 768px) {
    .desktop-controls {
      display: none;
    }
    .mobile-controls {
      display: block;
    }
  }

  .back-btn {
    padding: 8px 16px;
    background: transparent;
    color: rgba(255, 255, 255, 0.72);
    text-decoration: none;
    border-radius: 6px;
    transition: color 0.2s;
    border: none;
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
  }

  .back-btn:hover {
    color: rgba(255, 255, 255, 0.92);
  }

  #gameCanvas {
    border: 2px solid #1e293b;
    border-radius: 8px;
    background: #000;
    box-shadow: 0 0 30px rgba(0, 0, 0, 0.8);
    max-width: 100%;
    display: block;
  }

  .game-tips {
    margin-top: 16px;
    max-width: 1200px;
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
    justify-content: center;
  }

  .game-tips p {
    margin: 0;
    font-size: 13px;
    color: #64748b;
  }

  @media (max-width: 768px) {
    .game-header {
      flex-direction: column;
      align-items: flex-start;
    }

    .game-info h1 {
      font-size: 24px;
    }

    .game-tips {
      flex-direction: column;
      gap: 8px;
    }
  }
</style>

<script>
  // === TORNADO GAME ===
  const CANVAS_WIDTH = 1200;
  const CANVAS_HEIGHT = 700;
  const GRAVITY = 0.3;

  // Types
  type Vector = { x: number; y: number };
  type Building = Vector & {
    width: number;
    height: number;
    health: number;
    maxHealth: number;
    destroyed: boolean;
  };
  type Debris = Vector & {
    vx: number;
    vy: number;
    angle: number;
    angularVel: number;
    life: number;
    color: string;
    size: number;
  };
  type WindParticle = Vector & {
    vx: number;
    vy: number;
    life: number;
    opacity: number;
  };

  // Game state
  let gameRunning = true;
  let time = 0;
  let score = 0;
  let totalDamage = 0;

  let tornado = {
    x: 600,
    y: 350,
    vx: 0,
    vy: 0,
    size: 40,
    maxSize: 150,
    intensity: 0.5,
    rotation: 0,
    targetIntensity: 0.5,
  };

  let camera = { x: 0, y: 0 };
  let buildings: Building[] = [];
  let debris: Debris[] = [];
  let windParticles: WindParticle[] = [];
  let keys: { [key: string]: boolean } = {};
  let mouse = { x: 0, y: 0, worldX: 0, worldY: 0 };

  // === CANVAS SETUP ===
  const canvas = document.getElementById('gameCanvas') as HTMLCanvasElement;
  const ctx = canvas.getContext('2d')!;

  function resizeCanvas() {
    const maxWidth = Math.min(CANVAS_WIDTH, window.innerWidth - 40);
    const maxHeight = Math.min(CANVAS_HEIGHT, window.innerHeight - 250);
    const scale = Math.min(maxWidth / CANVAS_WIDTH, maxHeight / CANVAS_HEIGHT);
    
    canvas.width = CANVAS_WIDTH;
    canvas.height = CANVAS_HEIGHT;
    canvas.style.width = `${CANVAS_WIDTH * scale}px`;
    canvas.style.height = `${CANVAS_HEIGHT * scale}px`;
  }

  resizeCanvas();
  window.addEventListener('resize', resizeCanvas);

  // === INPUT ===
  window.addEventListener('keydown', (e) => {
    keys[e.key.toLowerCase()] = true;
    if (e.key === ' ') {
      e.preventDefault();
      tornado.targetIntensity = Math.min(tornado.targetIntensity + 0.15, 1.0);
    }
  });

  window.addEventListener('keyup', (e) => {
    keys[e.key.toLowerCase()] = false;
  });

  canvas.addEventListener('mousemove', (e) => {
    const rect = canvas.getBoundingClientRect();
    const scaleX = CANVAS_WIDTH / rect.width;
    const scaleY = CANVAS_HEIGHT / rect.height;
    
    mouse.x = (e.clientX - rect.left) * scaleX;
    mouse.y = (e.clientY - rect.top) * scaleY;
    mouse.worldX = mouse.x + camera.x;
    mouse.worldY = mouse.y + camera.y;
  });

  // Touch support
  canvas.addEventListener('touchmove', (e) => {
    e.preventDefault();
    const rect = canvas.getBoundingClientRect();
    const touch = e.touches[0];
    const scaleX = CANVAS_WIDTH / rect.width;
    const scaleY = CANVAS_HEIGHT / rect.height;
    
    mouse.x = (touch.clientX - rect.left) * scaleX;
    mouse.y = (touch.clientY - rect.top) * scaleY;
    mouse.worldX = mouse.x + camera.x;
    mouse.worldY = mouse.y + camera.y;
  }, { passive: false });

  // === INITIALIZATION ===
  function initGame() {
    generateCity();
  }

  function generateCity() {
    buildings = [];
    const rows = 5;
    const cols = 8;
    const spacing = 200;
    const startX = 100;
    const startY = 100;

    for (let row = 0; row < rows; row++) {
      for (let col = 0; col < cols; col++) {
        const x = startX + col * spacing;
        const y = startY + row * spacing;
        
        // Vary building sizes
        const sizeVariation = 20 + Math.random() * 40;
        const width = 60 + Math.random() * 40;
        const height = sizeVariation + Math.random() * 80;
        const health = Math.ceil((width + height) / 3);

        buildings.push({
          x,
          y,
          width,
          height,
          health,
          maxHealth: health,
          destroyed: false,
        });
      }
    }
  }

  // === TORNADO PHYSICS ===
  function updateTornado() {
    // Smooth intensity change
    tornado.intensity += (tornado.targetIntensity - tornado.intensity) * 0.05;
    
    // Size based on intensity
    tornado.size = 40 + tornado.intensity * 110;

    // Movement input
    let moveX = 0;
    let moveY = 0;
    if (keys['a'] || keys['arrowleft']) moveX = -1;
    if (keys['d'] || keys['arrowright']) moveX = 1;
    if (keys['w'] || keys['arrowup']) moveY = -1;
    if (keys['s'] || keys['arrowdown']) moveY = 1;

    // Apply acceleration
    const moveSpeed = 0.3;
    tornado.vx += moveX * moveSpeed;
    tornado.vy += moveY * moveSpeed;

    // Damping - tornado slowly loses momentum
    tornado.vx *= 0.92;
    tornado.vy *= 0.92;

    // Limit velocity based on intensity
    const maxSpeed = 2 + tornado.intensity * 4;
    const speed = Math.hypot(tornado.vx, tornado.vy);
    if (speed > maxSpeed) {
      tornado.vx = (tornado.vx / speed) * maxSpeed;
      tornado.vy = (tornado.vy / speed) * maxSpeed;
    }

    // Update position
    tornado.x += tornado.vx;
    tornado.y += tornado.vy;

    // Boundary constraints
    tornado.x = Math.max(tornado.size, Math.min(1200 - tornado.size, tornado.x));
    tornado.y = Math.max(tornado.size, Math.min(700 - tornado.size, tornado.y));

    // Rotation increases with intensity and movement
    const movementMagnitude = Math.hypot(tornado.vx, tornado.vy);
    tornado.rotation += (0.02 + tornado.intensity * 0.08 + movementMagnitude * 0.05) % (Math.PI * 2);

    // Create wind particles
    if (Math.random() < tornado.intensity * 0.5) {
      createWindParticle();
    }

    // Check for building collisions
    checkBuildingCollisions();
  }

  function createWindParticle() {
    const angle = Math.random() * Math.PI * 2;
    const distance = tornado.size * (0.5 + Math.random() * 0.5);
    const speed = 1 + tornado.intensity * 5;

    windParticles.push({
      x: tornado.x + Math.cos(angle) * distance,
      y: tornado.y + Math.sin(angle) * distance,
      vx: Math.cos(angle) * speed + (Math.random() - 0.5) * 0.5,
      vy: Math.sin(angle) * speed + (Math.random() - 0.5) * 0.5,
      life: 0.8,
      opacity: 0.3,
    });
  }

  function checkBuildingCollisions() {
    buildings.forEach((building, index) => {
      if (building.destroyed) return;

      // Check if tornado overlaps building
      const dx = tornado.x - building.x;
      const dy = tornado.y - building.y;
      const dist = Math.hypot(dx, dy);
      const minDist = tornado.size / 2 + Math.max(building.width, building.height) / 2;

      if (dist < minDist) {
        // Damage building based on tornado intensity
        const damage = 5 + tornado.intensity * 15;
        building.health -= damage;

        // Create debris
        createDebris(building.x, building.y, building.width, building.height, 10 + Math.ceil(tornado.intensity * 20));

        // Score
        const damagePoints = Math.ceil(damage);
        score += damagePoints;
        totalDamage += damagePoints;

        if (building.health <= 0) {
          building.destroyed = true;
          // Extra particles for destruction
          createDebris(building.x, building.y, building.width, building.height, 30);
        }

        // Update UI
        updateUI();
      }
    });
  }

  function createDebris(x: number, y: number, width: number, height: number, count: number) {
    const colors = ['#ff6b6b', '#ff8c42', '#ffd93d', '#6bcf7f', '#4d96ff'];
    
    for (let i = 0; i < count; i++) {
      const angle = (Math.random() * Math.PI * 2);
      const speed = 2 + Math.random() * 6 + tornado.intensity * 3;
      const size = 3 + Math.random() * 8;

      debris.push({
        x,
        y,
        vx: Math.cos(angle) * speed,
        vy: Math.sin(angle) * speed - 2,
        angle: Math.random() * Math.PI * 2,
        angularVel: (Math.random() - 0.5) * 0.2,
        life: 2.0,
        color: colors[Math.floor(Math.random() * colors.length)],
        size,
      });
    }
  }

  // === PARTICLE UPDATES ===
  function updateDebris() {
    debris = debris.filter(d => {
      d.x += d.vx;
      d.y += d.vy;
      d.vy += GRAVITY;
      d.angle += d.angularVel;
      d.vx *= 0.98;
      d.vy *= 0.98;
      d.life -= 0.01;
      return d.life > 0;
    });
  }

  function updateWindParticles() {
    windParticles = windParticles.filter(p => {
      p.x += p.vx;
      p.y += p.vy;
      
      // Gravity affects wind particles slightly
      p.vy += GRAVITY * 0.1;
      
      // Drag
      p.vx *= 0.96;
      p.vy *= 0.96;
      
      p.life -= 0.02;
      return p.life > 0;
    });
  }

  // === CAMERA ===
  function updateCamera() {
    // Smooth follow tornado
    camera.x += (tornado.x - CANVAS_WIDTH / 2 - camera.x) * 0.08;
    camera.y += (tornado.y - CANVAS_HEIGHT / 2 - camera.y) * 0.08;

    // Clamp camera
    camera.x = Math.max(0, Math.min(1200 - CANVAS_WIDTH, camera.x));
    camera.y = Math.max(0, Math.min(700 - CANVAS_HEIGHT, camera.y));
  }

  // === RENDERING ===
  function render() {
    // Clear with sky gradient
    const bgGradient = ctx.createLinearGradient(0, 0, 0, CANVAS_HEIGHT);
    bgGradient.addColorStop(0, '#1a1a2e');
    bgGradient.addColorStop(0.5, '#2d2d44');
    bgGradient.addColorStop(1, '#3d3d5c');
    ctx.fillStyle = bgGradient;
    ctx.fillRect(0, 0, CANVAS_WIDTH, CANVAS_HEIGHT);

    ctx.save();
    ctx.translate(-camera.x, -camera.y);

    // Draw buildings
    buildings.forEach(building => {
      if (building.destroyed) {
        // Draw rubble as lighter outline
        ctx.fillStyle = '#444444';
        ctx.fillRect(building.x - building.width / 2, building.y - building.height / 2, building.width, building.height);
      } else {
        // Building gradient based on damage
        const healthPercent = building.health / building.maxHealth;
        const hue = healthPercent > 0.6 ? 220 : healthPercent > 0.3 ? 40 : 0;
        
        // Building color
        ctx.fillStyle = `hsl(${hue}, 70%, ${healthPercent > 0.6 ? 60 : 50}%)`;
        ctx.fillRect(building.x - building.width / 2, building.y - building.height / 2, building.width, building.height);

        // Building outline and details
        ctx.strokeStyle = '#333';
        ctx.lineWidth = 2;
        ctx.strokeRect(building.x - building.width / 2, building.y - building.height / 2, building.width, building.height);

        // Windows
        ctx.fillStyle = '#ffff99';
        const windowSize = 8;
        const spacing = 15;
        for (let wx = -building.width / 3; wx < building.width / 3; wx += spacing) {
          for (let wy = -building.height / 3; wy < building.height / 3; wy += spacing) {
            ctx.fillRect(
              building.x + wx - windowSize / 2,
              building.y + wy - windowSize / 2,
              windowSize,
              windowSize
            );
          }
        }

        // Health bar
        const barWidth = building.width * 0.8;
        ctx.fillStyle = '#333';
        ctx.fillRect(
          building.x - barWidth / 2,
          building.y + building.height / 2 + 8,
          barWidth,
          3
        );
        ctx.fillStyle = healthPercent > 0.6 ? '#00ff00' : healthPercent > 0.3 ? '#ffff00' : '#ff0000';
        ctx.fillRect(
          building.x - barWidth / 2,
          building.y + building.height / 2 + 8,
          barWidth * healthPercent,
          3
        );
      }
    });

    // Draw wind particles
    windParticles.forEach(p => {
      ctx.globalAlpha = p.opacity * p.life;
      ctx.fillStyle = '#88ccff';
      ctx.beginPath();
      ctx.arc(p.x, p.y, 3, 0, Math.PI * 2);
      ctx.fill();
    });
    ctx.globalAlpha = 1;

    // Draw debris
    debris.forEach(d => {
      ctx.save();
      ctx.translate(d.x, d.y);
      ctx.rotate(d.angle);
      ctx.globalAlpha = d.life;
      ctx.fillStyle = d.color;
      ctx.fillRect(-d.size / 2, -d.size / 2, d.size, d.size);
      ctx.restore();
    });

    // Draw tornado - complex vortex effect
    drawTornado();

    ctx.restore();

    // Draw HUD
    drawHUD();
  }

  function drawTornado() {
    ctx.save();
    ctx.translate(tornado.x, tornado.y);
    ctx.rotate(tornado.rotation);

    // Outer wind ring
    ctx.strokeStyle = 'rgba(100, 150, 255, 0.2)';
    ctx.lineWidth = 3;
    for (let i = 0; i < 3; i++) {
      ctx.beginPath();
      ctx.arc(0, 0, tornado.size * (0.7 - i * 0.2), 0, Math.PI * 2);
      ctx.stroke();
    }

    // Core vortex - spiral effect
    ctx.strokeStyle = 'rgba(150, 200, 255, 0.6)';
    ctx.lineWidth = 2;
    
    for (let layer = 0; layer < 8; layer++) {
      ctx.beginPath();
      const pointCount = 20;
      for (let i = 0; i <= pointCount; i++) {
        const angle = (i / pointCount) * Math.PI * 2 + tornado.rotation * 2;
        const radius = (layer / 8) * tornado.size * 0.5;
        const x = Math.cos(angle) * radius;
        const y = Math.sin(angle) * radius;
        
        if (i === 0) ctx.moveTo(x, y);
        else ctx.lineTo(x, y);
      }
      ctx.stroke();
    }

    // Inner cone - darkest part
    const coneGradient = ctx.createRadialGradient(0, 0, 0, 0, 0, tornado.size * 0.3);
    coneGradient.addColorStop(0, 'rgba(200, 220, 255, 0.8)');
    coneGradient.addColorStop(0.5, 'rgba(100, 150, 255, 0.5)');
    coneGradient.addColorStop(1, 'rgba(50, 100, 200, 0.1)');
    ctx.fillStyle = coneGradient;
    ctx.beginPath();
    ctx.arc(0, 0, tornado.size * 0.3, 0, Math.PI * 2);
    ctx.fill();

    // Intensity indicators - spikes
    ctx.strokeStyle = `rgba(255, 200, 100, ${tornado.intensity})`;
    ctx.lineWidth = 2;
    for (let i = 0; i < 12; i++) {
      const angle = (i / 12) * Math.PI * 2 + tornado.rotation;
      const length = tornado.size * (0.3 + tornado.intensity * 0.5);
      ctx.beginPath();
      ctx.moveTo(0, 0);
      ctx.lineTo(Math.cos(angle) * length, Math.sin(angle) * length);
      ctx.stroke();
    }

    ctx.restore();
  }

  function drawHUD() {
    // Semi-transparent background
    ctx.fillStyle = 'rgba(0, 0, 0, 0.3)';
    ctx.fillRect(0, 0, CANVAS_WIDTH, 70);

    ctx.fillStyle = '#ffffff';
    ctx.font = 'bold 24px Arial';
    ctx.fillText(`Score: ${score}`, 20, 35);
    ctx.fillText(`Damage: ${totalDamage}`, 20, 60);

    // Intensity bar
    ctx.font = 'bold 12px Arial';
    ctx.fillText('Intensity:', CANVAS_WIDTH - 200, 25);
    ctx.fillStyle = '#444';
    ctx.fillRect(CANVAS_WIDTH - 120, 30, 100, 15);
    ctx.fillStyle = `hsl(${tornado.intensity * 120}, 100%, 50%)`;
    ctx.fillRect(CANVAS_WIDTH - 120, 30, tornado.intensity * 100, 15);

    // Instructions
    ctx.font = '11px Arial';
    ctx.fillStyle = '#aaaaaa';
    ctx.fillText('WASD/Arrows: Move  •  Space: Boost', CANVAS_WIDTH - 280, 60);
  }

  // === GAME LOOP ===
  function updateUI() {
    const damageEl = document.getElementById('damage');
    const scoreEl = document.getElementById('score');
    
    if (damageEl) damageEl.textContent = totalDamage.toString();
    if (scoreEl) scoreEl.textContent = score.toString();
  }

  let lastTime = performance.now();

  function gameLoop() {
    if (!gameRunning) return;

    const currentTime = performance.now();
    lastTime = currentTime;
    time = currentTime;

    updateTornado();
    updateDebris();
    updateWindParticles();
    updateCamera();
    render();

    requestAnimationFrame(gameLoop);
  }

  // === START ===
  initGame();
  gameLoop();
</script>
